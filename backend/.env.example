# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/class_memories?schema=public"

# ─── JWT ───
JWT_SECRET="change-this-to-a-random-secret"
JWT_EXPIRES_IN="7d"

# ─── Server ───
PORT=3000

# ─── CORS (逗号分隔多个来源) ───
# 生产环境改为你的域名: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── File Storage ───
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# ─── DeepSeek AI (可选) ───
DEEPSEEK_API_KEY=

# ─── Admin Seed (运行 prisma db seed 时使用) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@classmemories.com
