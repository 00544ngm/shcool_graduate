# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/class_memories?schema=public"

# ─── JWT ───
JWT_SECRET="change-this-to-a-random-secret"
JWT_EXPIRES_IN="7d"

# ─── Server ───
PORT=3000

# ─── Redis (optional) ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── File Storage ───
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# ─── DeepSeek AI (optional, or place key in apikey.txt) ───
DEEPSEEK_API_KEY=
