generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VISITOR
  MEMBER
  MODERATOR
  ADMIN
}

enum LetterStatus {
  SEALED
  OPENED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  nickname     String
  avatar       String?
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(MEMBER)
  bio          String?
  graduationPhoto String? @map("graduation_photo")
  dormitory    String?
  city         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  photos       Photo[]
  videos       Video[]
  comments     Comment[]
  moments      Moment[]
  letters      FutureLetter[]
  likes        Like[]
  notifications         Notification[]  @relation("NotificationRecipient")
  sentNotifications     Notification[]  @relation("NotificationSender")
  homeMessages          HomeMessage[]

  @@map("users")
}

model Photo {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String?
  description String?
  imageUrl    String   @map("image_url")
  takenAt     DateTime? @map("taken_at")
  location    String?
  tags        String[]
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])

  @@map("photos")
}

model Video {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String?
  videoUrl  String   @map("video_url")
  coverUrl  String?  @map("cover_url")
  duration  Int?
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("videos")
}

model Comment {
  id         String   @id @default(cuid())
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  userId     String   @map("user_id")
  content    String
  parentId   String?  @map("parent_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])
  parent     Comment? @relation("CommentReply", fields: [parentId], references: [id])
  replies    Comment[] @relation("CommentReply")

  @@map("comments")
}

model Moment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  content   String
  images    String[]
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("moments")
}

model FutureLetter {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  title      String
  content    String
  unlockTime DateTime     @map("unlock_time")
  status     LetterStatus @default(SEALED)
  createdAt  DateTime     @default(now()) @map("created_at")

  user       User         @relation(fields: [userId], references: [id])

  @@map("future_letters")
}

model Like {
  id         String @id @default(cuid())
  targetType String @map("target_type")
  targetId   String @map("target_id")
  userId     String @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User   @relation(fields: [userId], references: [id])

  @@unique([targetType, targetId, userId])
  @@map("likes")
}

model HomeMessage {
  id        String   @id @default(cuid())
  content   String
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("home_messages")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  fromUserId String?  @map("from_user_id")
  type       String
  content    String
  read       Boolean  @default(false)
  relatedId  String?  @map("related_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User @relation("NotificationRecipient", fields: [userId], references: [id])
  fromUser User? @relation("NotificationSender", fields: [fromUserId], references: [id])

  @@map("notifications")
}

model Favorite {
  id         String @id @default(cuid())
  targetType String @map("target_type")
  targetId   String @map("target_id")
  userId     String @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([targetType, targetId, userId])
  @@map("favorites")
}

model ChatQuota {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  date        String    @map("date")
  count       Int       @default(0)
  bannedUntil DateTime? @map("banned_until")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@map("chat_quotas")
}
